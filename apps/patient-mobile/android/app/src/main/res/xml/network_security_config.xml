<?xml version="1.0" encoding="utf-8"?>
<!--
  Allows cleartext HTTP traffic during development (local API + Keycloak).
  For production builds, set cleartextTrafficPermitted="false" or remove
  the base-config entirely so the platform default (HTTPS-only) applies.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true" />
    <debug-overrides>
        <trust-anchors>
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
