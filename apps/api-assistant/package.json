{
	"name": "api-assistant",
	"version": "1.0.0",
	"scripts": {
		"build": "tsc",
		"dev": "dotenv -e ../../.env -- ts-node-dev --respawn --transpile-only src/main.ts",
		"start": "node dist/main.js",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@clinic/api-common": "workspace:*",
