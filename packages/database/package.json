{
	"name": "@clinic/database",
	"version": "1.0.0",
	"main": "src/index.ts",
	"types": "src/index.ts",
	"publishConfig": {
		"main": "dist/index.js",
		"types": "dist/index.d.ts"
	},
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"generate": "dotenv -e ../../.env -- prisma generate",
		"migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
		"migrate:dev": "dotenv -e ../../.env -- prisma migrate dev",
		"migrate:reset": "dotenv -e ../../.env -- prisma migrate reset --force",
		"postinstall": "prisma generate",
		"seed": "dotenv -e ../../.env -- ts-node src/seed.ts",
		"studio": "dotenv -e ../../.env -- prisma studio",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@prisma/adapter-pg": "catalog:",
		"@prisma/client": "catalog:",
		"pg": "catalog:"
	},
	"devDependencies": {
		"@types/node": "catalog:",
		"@types/pg": "catalog:",
		"prisma": "catalog:",
		"ts-node": "^10.9.2",
		"typescript": "catalog:"
	}
}
