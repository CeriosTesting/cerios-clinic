generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  patient
  doctor
  assistant
  admin
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  CANCELLED
  COMPLETED
}

model User {
  id          String    @id @default(uuid())
  keycloakId  String    @unique @map("keycloak_id")
  email       String    @unique
  firstName   String    @map("first_name")
  lastName    String    @map("last_name")
  role        UserRole
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  patient   Patient?
  doctor    Doctor?
  assistant Assistant?

  @@index([role])
  @@index([deletedAt])
  @@map("users")
}

model Patient {
  id                        String  @id @default(uuid())
  userId                    String  @unique @map("user_id")
  dateOfBirth               DateTime? @map("date_of_birth")
  phone                     String?
  insuranceNumber           String? @map("insurance_number")
  photo                     String?
  emailNotificationsEnabled Boolean @default(true) @map("email_notifications_enabled")
  updatedAt                 DateTime  @updatedAt @map("updated_at")

  user          User           @relation(fields: [userId], references: [id])
  appointments  Appointment[]
  reviews       Review[]
  prescriptions Prescription[]

  @@map("patients")
}

model Doctor {
  id             String  @id @default(uuid())
  userId         String  @unique @map("user_id")
  specialization String?
  licenseNumber  String? @map("license_number")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user            User                  @relation(fields: [userId], references: [id])
  appointments    Appointment[]
  unavailability  DoctorUnavailability[]
  reviews         Review[]
  prescriptions   Prescription[]

  @@map("doctors")
}

model Assistant {
  id         String  @id @default(uuid())
  userId     String  @unique @map("user_id")
  department String?
  updatedAt  DateTime  @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id])
  appointments Appointment[]

  @@map("assistants")
}

model Appointment {
  id          String            @id @default(uuid())
  patientId   String            @map("patient_id")
  doctorId    String            @map("doctor_id")
  assistantId String?           @map("assistant_id")
  scheduledAt DateTime          @map("scheduled_at")
  status      AppointmentStatus @default(SCHEDULED)
  notes       String?
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  patient   Patient    @relation(fields: [patientId], references: [id])
  doctor    Doctor     @relation(fields: [doctorId], references: [id])
  assistant Assistant? @relation(fields: [assistantId], references: [id])

  statusHistory AppointmentStatusChange[]
  review        Review?
  prescription  Prescription?

  @@index([patientId])
  @@index([doctorId])
  @@index([scheduledAt])
  @@index([status])
  @@index([assistantId])
  @@index([patientId, status])
  @@index([patientId, scheduledAt])
  @@index([doctorId, scheduledAt])
  @@map("appointments")
}

model AppointmentStatusChange {
  id                   String             @id @default(uuid())
  appointmentId        String             @map("appointment_id")
  previousStatus       AppointmentStatus? @map("previous_status")
  newStatus            AppointmentStatus  @map("new_status")
  previousScheduledAt  DateTime?          @map("previous_scheduled_at")
  newScheduledAt       DateTime?          @map("new_scheduled_at")
  changedByKeycloakId  String             @map("changed_by_keycloak_id")
  changedAt            DateTime           @default(now()) @map("changed_at")

  appointment Appointment @relation(fields: [appointmentId], references: [id])

  @@index([appointmentId])
  @@map("appointment_status_changes")
}

model Review {
  id            String   @id @default(uuid())
  appointmentId String   @unique @map("appointment_id")
  patientId     String   @map("patient_id")
  doctorId      String   @map("doctor_id")
  rating        Int
  comment       String?
  createdAt     DateTime @default(now()) @map("created_at")

  appointment Appointment @relation(fields: [appointmentId], references: [id])
  patient     Patient     @relation(fields: [patientId], references: [id])
  doctor      Doctor      @relation(fields: [doctorId], references: [id])

  @@index([patientId])
  @@index([doctorId])
  @@map("reviews")
}

model DoctorUnavailability {
  id        String   @id @default(uuid())
  doctorId  String   @map("doctor_id")
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")

  doctor Doctor @relation(fields: [doctorId], references: [id])

  @@index([doctorId])
  @@index([doctorId, startDate, endDate])
  @@map("doctor_unavailability")
}

model Prescription {
  id            String   @id @default(uuid())
  appointmentId String   @unique @map("appointment_id")
  patientId     String   @map("patient_id")
  doctorId      String   @map("doctor_id")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  appointment Appointment        @relation(fields: [appointmentId], references: [id])
  patient     Patient            @relation(fields: [patientId], references: [id])
  doctor      Doctor             @relation(fields: [doctorId], references: [id])
  items       PrescriptionItem[]

  @@index([patientId])
  @@index([doctorId])
  @@map("prescriptions")
}

model PrescriptionItem {
  id             String @id @default(uuid())
  prescriptionId String @map("prescription_id")
  medicationName String @map("medication_name")
  dosage         String
  frequency      String
  duration       String
  instructions   String?

  prescription Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  @@index([prescriptionId])
  @@map("prescription_items")
}
