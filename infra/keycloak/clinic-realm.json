{
	"realm": "clinic",
	"enabled": true,
	"displayName": "Clinic Portal",
	"registrationAllowed": false,
	"registrationEmailAsUsername": true,
	"loginWithEmailAllowed": true,
	"duplicateEmailsAllowed": false,
	"resetPasswordAllowed": true,
	"editUsernameAllowed": false,
	"bruteForceProtected": true,
	"smtpServer": {
		"host": "mailpit",
		"port": "1025",
		"from": "noreply@clinic.local",
		"fromDisplayName": "Clinic System",
		"ssl": "false",
		"starttls": "false",
		"auth": "false"
	},
	"roles": {
		"realm": [
			{ "name": "patient", "description": "Patient user" },
			{ "name": "doctor", "description": "Doctor user" },
			{ "name": "assistant", "description": "Medical assistant user" },
			{ "name": "admin", "description": "System administrator" }
		]
